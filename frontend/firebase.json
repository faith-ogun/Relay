{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "//": "Content-hashed JS/CSS bundles never change for a given URL — cache forever.",
        "source": "/assets/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      },
      {
        "//": "Static media (card art, mascots, fonts) is stable per filename — cache long, revalidate on deploy.",
        "source": "**/*.@(webp|png|jpg|jpeg|gif|svg|ico|woff2|mp3|wav)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=2592000" }]
      },
      {
        "//": "The SPA shell must always revalidate, or a deploy never reaches returning users.",
        "source": "/index.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
