# vision-verifier — local env (gitignored copy lives in .env)
# Run locally on port 8084 (live-bridge=8082, quiz-engine=8083).
#
#   python3 -m venv .venv && source .venv/bin/activate
#   pip install -r requirements.txt
#   PYTHONPATH=app uvicorn app.main:app --host 0.0.0.0 --port 8084 --reload

# Vertex AI (no API key needed on Cloud Run; uses the service account).
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=ohmlet-app
# Gemini 3.5 Flash is served from the `global` Vertex location.
GOOGLE_CLOUD_LOCATION=global

# Or, for local dev without Vertex, set an API key instead:
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
# GOOGLE_API_KEY=...

# Observability (#35): token that guards /internal/metrics. Leave unset to make
# the endpoint return 404 (the safe default).
# OHMLET_METRICS_TOKEN=...

# CORS allowlist override (defaults to Ohmlet's own origins + localhost).
# OHMLET_ALLOWED_ORIGINS=https://ohmlet.org,http://localhost:3000
