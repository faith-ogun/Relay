# Relay Live Bridge environment variables

# Google AI API key (for local dev without Vertex AI)
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your-google-ai-api-key

# Models — multi-model routing
# Vertex AI: gemini-live-2.5-flash-native-audio
# Google AI: gemini-2.5-flash-native-audio-preview-12-2025
RELAY_LIVE_MODEL=gemini-live-2.5-flash-native-audio
RELAY_FLASH_MODEL=gemini-3.1-flash-preview
RELAY_PRO_MODEL=gemini-3.1-pro-preview
RELAY_REASONING_MODEL=gemini-2.5-pro

# App name for ADK session tracking
RELAY_APP_NAME=relay-live-bridge

# For Vertex AI (production / Cloud Run):
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=relay-gemini
# GOOGLE_CLOUD_LOCATION=europe-west1
