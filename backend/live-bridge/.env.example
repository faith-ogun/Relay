# Ohmlet Live Bridge environment variables

# Google AI API key (for local dev without Vertex AI)
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your-google-ai-api-key

# Models — multi-model routing
# Vertex AI: gemini-live-2.5-flash-native-audio
# Google AI: gemini-2.5-flash-native-audio-preview-12-2025
OHMLET_LIVE_MODEL=gemini-live-2.5-flash-native-audio
OHMLET_FLASH_MODEL=gemini-2.5-flash
OHMLET_PRO_MODEL=gemini-2.5-pro
OHMLET_REASONING_MODEL=gemini-2.5-pro

# App name for ADK session tracking
OHMLET_APP_NAME=ohmlet-live-bridge

# For Vertex AI (production / Cloud Run):
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=ohmlet-app
# GOOGLE_CLOUD_LOCATION=europe-west1
