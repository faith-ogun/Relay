# reporter — local env (gitignored copy lives in .env)
# Run locally on port 8085 (live-bridge=8082, quiz=8083, vision=8084, compiler=local).
#
#   python3 -m venv .venv && source .venv/bin/activate
#   pip install -r requirements.txt
#   PYTHONPATH=app uvicorn app.main:app --host 0.0.0.0 --port 8085 --reload

GOOGLE_CLOUD_PROJECT=ohmlet-app

# 3D generation provider (true image -> mesh). Default 'stability'; set to 'none'
# to disable (the API then returns a clean 503 instead of faking an artifact).
OHMLET_TWIN_PROVIDER=stability
# The provider API key is a SECRET — in production it is injected from Secret
# Manager at deploy, never committed. For local dev only:
# STABILITY_API_KEY=...

# Storage (created by ops/backup-style setup; see README).
OHMLET_TWINS_BUCKET=ohmlet-app-twins
OHMLET_TWINS_COLLECTION=ohmlet_twins

# Monthly twin quota per plan (env-tunable policy, not a hard contract).
OHMLET_TWINS_FREE=1
OHMLET_TWINS_PRO=30
OHMLET_TWINS_MAX=100

# Observability (#35): token guarding /internal/metrics. Unset -> 404 (safe default).
# OHMLET_METRICS_TOKEN=...
